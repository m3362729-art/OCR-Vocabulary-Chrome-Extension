{
  "manifest_version": 3,
  "name": "OCR 單字本",
  "version": "1.0.0",
  "description": "螢幕 OCR 擷取英文單字，自動翻譯並儲存為單字卡片",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "scripting"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/selection.js", "content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "commands": {
    "trigger-ocr": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "啟動 OCR 選取模式"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
